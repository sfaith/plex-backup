#!/bin/bash
# plex-backup-validate.sh — Validate Plex backup integrity on NAS
# Runs against NAS copy only — zero Plex downtime.
# Usage: plex-backup-validate.sh [YYYY-MM-DD]
# If no date given, validates flat Plex/ backup directory.
# Copy this file to plex-backup-validate.sh before running — do not run the .example directly.
#
# What this script checks and why:
#
#   1. NFS mount reachable     — no point validating if we can't see the backup
#   2. Backup age              — detects missed cron runs (threshold: WARN_AGE_HOURS)
#   3. Required files present  — confirms critical DBs and config were transferred
#   4. Backup size             — gross sanity check; a suspiciously small backup is a red flag
#
# What this script does NOT check and why:
#
#   SQLite integrity checks (PRAGMA integrity_check / quick_check) were attempted
#   against the two main Plex library databases but fail with "unknown tokenizer:
#   collating" because Plex ships its own custom SQLite build with proprietary
#   tokenizers. The system sqlite3 binary cannot check these files. Since the
#   only DBs that pass are minor (dlna, Music Analysis), sqlite3 checks were
#   dropped entirely to avoid false failures and misleading output.
#
#   File hashing was considered but rejected for this use case. With a single
#   rolling copy, a hash manifest would be regenerated on every backup run,
#   meaning it could only detect NAS-side bit-rot between runs — an unlikely
#   failure mode on Synology hardware. If dated snapshots are added in future,
#   hashing becomes more valuable and should be revisited.

set -euo pipefail

CONF_FILE="/etc/plex-backup/plex-backup.conf"

if [ ! -f "${CONF_FILE}" ]; then
    echo "ERROR: Config file not found: ${CONF_FILE}"
    echo "Run setup.sh or copy plex-backup.conf.example to ${CONF_FILE} and edit it."
    exit 1
fi

# shellcheck source=/dev/null
source "${CONF_FILE}"

# Files that must exist in a valid backup
REQUIRED_FILES=(
    "Preferences.xml"
    "Plug-in Support/Databases/com.plexapp.plugins.library.db"
    "Plug-in Support/Databases/com.plexapp.plugins.library.blobs.db"
)

# =============================================================================
# DERIVED — do not edit below this line
# =============================================================================
DATE=$(date +%Y-%m-%d)
LOG_FILE="${LOG_DIR}/plex-validate-${DATE}.log"
EXIT_CODE=0

mkdir -p "${LOG_DIR}"
exec > >(tee -a "${LOG_FILE}") 2>&1

echo "[$(date)] Starting Plex backup validation"

# --- ntfy helper ---
ntfy_send() {
    local title="$1"
    local message="$2"
    local priority="${3:-default}"
    [ -z "${NTFY_TOPIC}" ] && return 0
    curl -s -o /dev/null \
        -H "Title: ${title}" \
        -H "Priority: ${priority}" \
        -d "${message}" \
        "${NTFY_URL}/${NTFY_TOPIC}"
}

# --- Mount check ---
if ! mountpoint -q "$(dirname "${BACKUP_DEST}")"; then
    echo "[$(date)] ERROR: NFS mount not available. Aborting."
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Validate FAILED" "NFS mount not available — validation did not run" "high"
    exit 1
fi

# --- Validate date argument if provided ---
# Note: The date argument is reserved for future snapshot/dated-copy support.
# Current backup strategy is a single rolling copy; passing a date will look
# for a subdirectory that does not exist under normal operation.
if [ -n "${1:-}" ]; then
    if ! echo "$1" | grep -qE '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'; then
        echo "[$(date)] ERROR: Invalid date format '$1' — expected YYYY-MM-DD"
        exit 1
    fi
    SNAPSHOT="${BACKUP_DEST}/$1"
else
    SNAPSHOT="${BACKUP_DEST}"
fi

if [ ! -d "${SNAPSHOT}" ]; then
    echo "[$(date)] ERROR: Backup not found: ${SNAPSHOT}"
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Validate FAILED" "Backup not found — check NAS" "high"
    exit 1
fi

echo "[$(date)] Validating: ${SNAPSHOT}"

# --- Check backup age ---
NEWEST=$(find "${SNAPSHOT}" -name "Preferences.xml" -printf "%T@\n" 2>/dev/null | sort -n | tail -1)
if [ -n "${NEWEST}" ]; then
    NOW_EPOCH=$(date +%s)
    NEWEST_INT=${NEWEST%.*}
    AGE_HOURS=$(( (NOW_EPOCH - NEWEST_INT) / 3600 ))
    if [ "${AGE_HOURS}" -gt "${WARN_AGE_HOURS}" ]; then
        echo "[$(date)] WARNING: Backup is ${AGE_HOURS} hours old (threshold: ${WARN_AGE_HOURS}h)"
        EXIT_CODE=1
    else
        echo "[$(date)] OK: Backup age is ${AGE_HOURS} hours"
    fi
else
    echo "[$(date)] WARNING: Could not determine backup age"
    EXIT_CODE=1
fi

# --- Check required files ---
echo "[$(date)] Checking required files..."
for f in "${REQUIRED_FILES[@]}"; do
    if [ ! -f "${SNAPSHOT}/${f}" ]; then
        echo "[$(date)] ERROR: Missing required file: ${f}"
        EXIT_CODE=1
    else
        SIZE=$(du -sh "${SNAPSHOT}/${f}" 2>/dev/null | cut -f1)
        echo "[$(date)] OK: ${f} (${SIZE})"
    fi
done

# --- Backup size ---
TOTAL_SIZE=$(du -sh "${SNAPSHOT}" 2>/dev/null | cut -f1)
echo "[$(date)] Total Plex backup size: ${TOTAL_SIZE}"

# --- Tautulli validation (optional) ---
if [ "${TAUTULLI_ENABLED:-false}" = "true" ]; then
    echo "[$(date)] Validating Tautulli backup at ${TAUTULLI_BACKUP_DEST}"

    if [ ! -d "${TAUTULLI_BACKUP_DEST}" ]; then
        echo "[$(date)] ERROR: Tautulli backup destination not found: ${TAUTULLI_BACKUP_DEST}"
        EXIT_CODE=1
    else
        TAUTULLI_REQUIRED_FILES=(
            "tautulli.db"
            "config.ini"
        )

        for f in "${TAUTULLI_REQUIRED_FILES[@]}"; do
            if [ ! -f "${TAUTULLI_BACKUP_DEST}/${f}" ]; then
                echo "[$(date)] ERROR: Missing Tautulli file: ${f}"
                EXIT_CODE=1
            else
                SIZE=$(du -sh "${TAUTULLI_BACKUP_DEST}/${f}" 2>/dev/null | cut -f1)
                echo "[$(date)] OK: ${f} (${SIZE})"
            fi
        done

        TAUTULLI_SIZE=$(du -sh "${TAUTULLI_BACKUP_DEST}" 2>/dev/null | cut -f1)
        echo "[$(date)] Total Tautulli backup size: ${TAUTULLI_SIZE}"
    fi
fi

# --- Final result ---
if [ ${EXIT_CODE} -eq 0 ]; then
    echo "[$(date)] Validation PASSED"
    [ "${NTFY_ON_SUCCESS}" = "true" ] && ntfy_send "Plex Validate OK" "Backup validation passed — size: ${TOTAL_SIZE}" "default"
else
    echo "[$(date)] Validation FAILED — review log on plex server"
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Validate FAILED" "Backup validation failed — review log on plex server" "high"
fi

# --- Prune old logs ---
find "${LOG_DIR}" -name "plex-validate-*.log" -mtime +${LOG_RETAIN_DAYS} -delete

exit ${EXIT_CODE}
