# plex-backup.conf — Configuration for plex-backup scripts
# Generated by setup.sh or copied and edited manually.
# Location: /etc/plex-backup/plex-backup.conf
# Permissions: sudo chmod 600 /etc/plex-backup/plex-backup.conf
#              sudo chown root:root /etc/plex-backup/plex-backup.conf

# =============================================================================
# Plex Media Server
# =============================================================================

# Full path to Plex Media Server data directory
PLEX_DATA="/var/lib/plexmediaserver/Library/Application Support/Plex Media Server"

# systemd service name for Plex Media Server
PLEX_SERVICE="plexmediaserver"

# =============================================================================
# Backup destination
# =============================================================================

# Full path where Plex data will be backed up (NFS mount subdirectory or local path)
BACKUP_DEST="/mnt/nfs/YOUR_NAS_IP_OR_HOSTNAME/backups/Plex"

# =============================================================================
# NFS mount (optional)
# Only needed if BACKUP_DEST is on an NFS share.
# Leave NFS_EXPORT blank to skip NFS configuration entirely.
# =============================================================================

NFS_EXPORT=""
NFS_MOUNT_POINT=""
NFS_OPTS="vers=3,soft,rsize=131072,wsize=131072,timeo=600,retrans=2,_netdev"

# =============================================================================
# Logging
# =============================================================================

# Directory to write backup and validation logs
LOG_DIR="/var/log/plex-backup"

# Number of days to retain logs
LOG_RETAIN_DAYS=7

# =============================================================================
# Validation
# =============================================================================

# Warn if backup is older than this many hours (should be > backup interval)
WARN_AGE_HOURS=25

# =============================================================================
# ntfy alerting
# =============================================================================

# Set NTFY_TOPIC="" to disable alerting entirely
NTFY_TOPIC=""
NTFY_URL="https://ntfy.sh"
NTFY_ON_FAILURE=true
NTFY_ON_SUCCESS=false

# =============================================================================
# Tautulli
# =============================================================================

# Set to true to enable Tautulli backup and validation
TAUTULLI_ENABLED=false

# Full path to Tautulli installation directory
TAUTULLI_DATA="/opt/Tautulli"

# Full path where Tautulli data will be backed up
TAUTULLI_BACKUP_DEST="/mnt/nfs/YOUR_NAS_IP_OR_HOSTNAME/backups/Tautulli"
