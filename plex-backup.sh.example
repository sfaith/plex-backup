#!/bin/bash
# plex-backup.sh — Stop Plex, rsync config/DBs to NAS, restart Plex
# Single rolling copy. Configuration is read from /etc/plex-backup/plex-backup.conf
# Copy this file to plex-backup.sh before running — do not run the .example directly.

set -euo pipefail

CONF_FILE="/etc/plex-backup/plex-backup.conf"

if [ ! -f "${CONF_FILE}" ]; then
    echo "ERROR: Config file not found: ${CONF_FILE}"
    echo "Run setup.sh or copy plex-backup.conf.example to ${CONF_FILE} and edit it."
    exit 1
fi

# shellcheck source=/dev/null
source "${CONF_FILE}"

# =============================================================================
# DERIVED — do not edit below this line
# =============================================================================
DATE=$(date +%Y-%m-%d)
LOG_FILE="${LOG_DIR}/plex-backup-${DATE}.log"

mkdir -p "${LOG_DIR}"
exec > >(tee -a "${LOG_FILE}") 2>&1

echo "[$(date)] Starting Plex backup"

# --- ntfy helper ---
ntfy_send() {
    local title="$1"
    local message="$2"
    local priority="${3:-default}"
    [ -z "${NTFY_TOPIC}" ] && return 0
    curl -s -o /dev/null \
        -H "Title: ${title}" \
        -H "Priority: ${priority}" \
        -d "${message}" \
        "${NTFY_URL}/${NTFY_TOPIC}"
}

# --- Mount check ---
if ! mountpoint -q "$(dirname "${BACKUP_DEST}")"; then
    echo "[$(date)] ERROR: NFS mount not available. Aborting."
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Backup FAILED" "NFS mount not available — backup did not run" "high"
    exit 1
fi

# --- Stop Plex ---
echo "[$(date)] Stopping ${PLEX_SERVICE}"
if ! systemctl stop "${PLEX_SERVICE}"; then
    echo "[$(date)] WARNING: systemctl stop returned non-zero — service may already be stopped"
fi

STOP_WAIT=0
while systemctl is-active --quiet "${PLEX_SERVICE}" && [ ${STOP_WAIT} -lt 30 ]; do
    sleep 1
    STOP_WAIT=$(( STOP_WAIT + 1 ))
done

if systemctl is-active --quiet "${PLEX_SERVICE}"; then
    echo "[$(date)] ERROR: ${PLEX_SERVICE} did not stop within 30 seconds. Aborting."
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Backup FAILED" "Plex did not stop within 30 seconds — backup aborted" "high"
    exit 1
fi

echo "[$(date)] ${PLEX_SERVICE} stopped after ${STOP_WAIT}s"

# --- rsync ---
echo "[$(date)] Starting rsync to ${BACKUP_DEST}"
rsync -aH --delete \
    --no-owner --no-group --no-perms \
    --timeout=300 \
    --exclude="Cache/" \
    --exclude="Caches/" \
    --exclude="Crash Reports/" \
    --exclude="Logs/" \
    --exclude="Plug-in Support/Caches/" \
    --exclude="Plug-in Support/Databases/dbtmp/" \
    "${PLEX_DATA}/" "${BACKUP_DEST}/"
RSYNC_EXIT=$?

# --- Restart Plex regardless of rsync result ---
echo "[$(date)] Starting ${PLEX_SERVICE}"
if ! systemctl start "${PLEX_SERVICE}"; then
    echo "[$(date)] ERROR: Failed to start ${PLEX_SERVICE}"
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Backup WARNING" "Backup complete but Plex failed to restart — check server" "high"
    exit 1
fi

START_WAIT=0
while ! systemctl is-active --quiet "${PLEX_SERVICE}" && [ ${START_WAIT} -lt 30 ]; do
    sleep 1
    START_WAIT=$(( START_WAIT + 1 ))
done

if ! systemctl is-active --quiet "${PLEX_SERVICE}"; then
    echo "[$(date)] ERROR: ${PLEX_SERVICE} did not start within 30 seconds"
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Backup WARNING" "Backup complete but Plex failed to restart — check server" "high"
    exit 1
fi

echo "[$(date)] ${PLEX_SERVICE} started after ${START_WAIT}s"

# --- Check rsync result ---
if [ ${RSYNC_EXIT} -ne 0 ]; then
    echo "[$(date)] ERROR: rsync exited with code ${RSYNC_EXIT}"
    [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Plex Backup FAILED" "rsync error (code ${RSYNC_EXIT}) — check ${LOG_DIR} on plex server" "high"
    exit ${RSYNC_EXIT}
fi

echo "[$(date)] Plex backup complete"

# --- Tautulli backup (optional) ---
if [ "${TAUTULLI_ENABLED:-false}" = "true" ]; then
    echo "[$(date)] Starting Tautulli backup to ${TAUTULLI_BACKUP_DEST}"
    mkdir -p "${TAUTULLI_BACKUP_DEST}"
    rsync -aH --delete \
        --no-owner --no-group --no-perms \
        --timeout=300 \
        --include="tautulli.db" \
        --include="config.ini" \
        --include="config.bak" \
        --include="data/" \
        --include="data/**" \
        --exclude="*" \
        "${TAUTULLI_DATA}/" "${TAUTULLI_BACKUP_DEST}/"
    TAUTULLI_RSYNC_EXIT=$?
    if [ ${TAUTULLI_RSYNC_EXIT} -ne 0 ]; then
        echo "[$(date)] ERROR: Tautulli rsync exited with code ${TAUTULLI_RSYNC_EXIT}"
        [ "${NTFY_ON_FAILURE}" = "true" ] && ntfy_send "Tautulli Backup FAILED" "Tautulli rsync error (code ${TAUTULLI_RSYNC_EXIT}) — check ${LOG_DIR}" "high"
        exit ${TAUTULLI_RSYNC_EXIT}
    fi
    echo "[$(date)] Tautulli backup complete"
fi

# --- Run validation ---
VALIDATE_SCRIPT="$(dirname "$0")/plex-backup-validate.sh"
if [ -x "${VALIDATE_SCRIPT}" ]; then
    echo "[$(date)] Running validation"
    "${VALIDATE_SCRIPT}"
else
    echo "[$(date)] WARNING: Validation script not found or not executable: ${VALIDATE_SCRIPT}"
fi

[ "${NTFY_ON_SUCCESS}" = "true" ] && ntfy_send "Plex Backup OK" "Backup completed successfully" "default"

# --- Prune old logs ---
find "${LOG_DIR}" -name "plex-backup-*.log" -mtime +${LOG_RETAIN_DAYS} -delete
